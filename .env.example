# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY_BACKEND=                   # Your Google Gemini API key

# ── Optional (defaults shown) ─────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash     # Model to use
AI_TIMEOUT_MS=45000               # Per-request AI timeout in ms
AI_CONCURRENCY=5                  # Max parallel AI requests
CORS_ORIGIN=*                     # Restrict to your frontend URL in production (e.g. https://your-app.vercel.app)
PORT=3000                         # HTTP port (Railway sets this automatically)